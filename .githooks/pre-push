#!/usr/bin/env bash
# GitHub (origin): only allow pushes from local dev branch.
# Allowed targets on origin: dev (normal) and main (release via dev:main).
# Install: make install-git-hooks

set -euo pipefail

remote="${1:-}"

if [[ "$remote" != "origin" ]]; then
  exit 0
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  # Allow deleting stray branches on GitHub (cleanup).
  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    continue
  fi

  if [[ "$local_ref" != refs/heads/dev ]]; then
    echo "✗ 拒绝 push 到 origin：仅允许从本地 dev 推送（当前: ${local_ref#refs/heads/}）" >&2
    echo "  功能/Cloud 分支请推 private。" >&2
    exit 1
  fi

  if [[ "$remote_ref" != refs/heads/dev && "$remote_ref" != refs/heads/main ]]; then
    echo "✗ 拒绝 push 到 origin：目标仅允许 dev 或 main（当前: ${remote_ref#refs/heads/}）" >&2
    echo "  发布 main 请用: git push origin dev:main" >&2
    exit 1
  fi
done

exit 0

# mchat Docker lite environment
# Copy to ops/docker/.env and adjust as needed

# ---- Database ----
DATABASE_URL="mysql+aiomysql://mchat:mchat123@mysql:3306/mchat"
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=mchat
MYSQL_USER=mchat
MYSQL_PASSWORD=mchat123
MYSQL_PORT=3307

# ---- Backend ----
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
BACKEND_PORT=3001

# ---- JWT ----
JWT_SECRET=change-me-to-a-random-secret-key-at-least-32-chars
JWT_EXPIRE_MINUTES=10080

# ---- Admin ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3001

# ---- Milvus (optional) ----
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_ENABLED=false

# ---- Redis (optional) ----
REDIS_URL=redis://redis:6379

# ---- Embedding (optional) ----
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ---- Web search (optional) ----
SERPER_API_KEY=

# ---- Storage (optional) ----
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mchat-uploads
S3_USE_SSL=false
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

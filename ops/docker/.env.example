# ============================================
# mchat 环境变量配置
# 复制此文件为 .env 并修改配置
# ============================================

# ---- 数据库 ----
DATABASE_URL="mysql+aiomysql://mchat:mchat_password@mysql:3306/mchat"
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=mchat
MYSQL_USER=mchat
MYSQL_PASSWORD=mchat_password_change_me
MYSQL_PORT=3306

# ---- 后端服务 ----
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
BACKEND_PORT=3001

# ---- JWT ----
JWT_SECRET=change-me-to-a-random-secret-key-at-least-32-chars
JWT_EXPIRE_MINUTES=10080

# ---- 管理员 ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_change_me

# ---- 前端 ----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3001

# ---- Milvus 向量数据库（可选） ----
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_ENABLED=false

# ---- Redis（可选，用于跨实例广播） ----
REDIS_URL=redis://redis:6379

# ---- 嵌入模型（用于知识库向量化） ----
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ---- 联网搜索（可选） ----
SERPER_API_KEY=

# ---- MinIO / S3 文件存储（可选） ----
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mchat-uploads
S3_USE_SSL=false

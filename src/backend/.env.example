# Database (lite MySQL; make setup syncs from ops/docker/.env, default host port 3307)
DATABASE_URL=mysql+aiomysql://mchat:mchat123@localhost:3307/mchat

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Milvus (optional - RAG feature)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ENABLED=false

# LLM API keys (optional fallback when an AI config row has an empty key)
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# MOONSHOT_API_KEY=sk-...

# Embedding (global defaults; each knowledge base can override)
# 推荐本地 Ollama：ollama pull nomic-embed-text
# Embedding：建议在管理后台「知识库 → 系统默认 Embedding」配置并保存（写入 DB），无需在此设置。
# 下列仅在未保存后台配置时作为兜底：
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_BASE=http://localhost:11434
# EMBEDDING_DIMENSION=768
# EMBEDDING_API_KEY=
# 本地上传 Embedding 模型 zip 大小上限（MB）
EMBEDDING_MODEL_MAX_MB=2048

# Redis (OTP for Cloud portal signup; rate limiting)
REDIS_URL=redis://localhost:6379/0

# Cloud portal: phone SMS signup (dev: fixed code; prod: Aliyun like 9235.net)
SMS_DEV_MODE=true
SMS_DEV_CODE=123456
OTP_EXPIRE_SECONDS=600
OTP_SEND_COOLDOWN_SECONDS=60
# Same Aliyun account/template as patentapi (basebase.xml + SMS_289525897)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=笑溢网络
ALIYUN_SMS_TEMPLATE_CODE=SMS_289525897
ALIYUN_SMS_REGION=cn-hangzhou

# Patent portal / SSO (optional — leave empty for white-label deployments)
# PATENT9235_BASE_URL=https://www.example.com
# PATENT_PORTAL_URL_TEMPLATE=https://www.example.com/patent/{patent_id}.html
PATENT9235_JWT_SECRET=
PATENT9235_SSO_PRODUCT_ID=pdmchat
PATENT9235_SSO_CHANNEL_ID=mchat01
PATENT9235_SSO_LOGIN_URL=

# Payment & public URL (your deployment)
MCHAT_PUBLIC_BASE_URL=https://mchat.example.com
ALIPAY_APP_ID=2021004152628243
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
WECHAT_PAY_APP_ID=wx72863a0d11e809e0
WECHAT_PAY_MCH_ID=1679561189
WECHAT_PAY_API_KEY=

# Encrypt skill_bindings secrets at rest (Fernet; generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRETS_ENCRYPTION_KEY=
INVOICE_COMPANY_NAME=MChat Cloud
INVOICE_COMPANY_TAX_ID=
INVOICE_SUPPORT_EMAIL=support@example.com

# Default admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
# development | production (production rejects default JWT/admin password)
ENVIRONMENT=development

# Independent background worker (standard mode; default off)
WORKER_ENABLED=false
WORKER_TIMEZONE=Asia/Shanghai
# Daily log cleanup
WORKER_LOG_CLEANUP_ENABLED=true
WORKER_LOG_RETENTION_DAYS=14
# Monthly usage reset for channel quotas
WORKER_USAGE_RESET_ENABLED=true

# Skills directory
SKILLS_DIR=./skills

# Workflow orchestration (Beta)
# Optional webhook for failed runs / rejected approvals (JSON POST)
# WORKFLOW_ALERT_WEBHOOK_URL=https://example.com/hooks/workflow-alert

# Tenant workspace (Plan A local + Plan B container sidecar; Core + Cloud)
WORKSPACE_ROOT_DIR=../../data/tenants
WORKSPACE_DEFAULT_MODE=local
# Sidecar hardening (Phase 1)
# WORKSPACE_CONTAINER_NETWORK=none
# WORKSPACE_CONTAINER_PIDS_LIMIT=256
# WORKSPACE_CONTAINER_MEMORY=512m
# WORKSPACE_CONTAINER_CPUS=1.0
WORKSPACE_CONTAINER_ENABLED=false
WORKSPACE_CONTAINER_IMAGE=python:3.12-slim
# Idle sidecar recycle (worker job every 15m when enabled)
WORKSPACE_SIDECAR_IDLE_MINUTES=120
WORKSPACE_SIDECAR_RECYCLE_ENABLED=false
# Legacy Cloud studio path; leave empty to use {WORKSPACE_ROOT_DIR}/{user_id}/studio/{channel_id}
# WORKSPACE_LEGACY_STUDIO_DIR=../../data/studio

# File uploads
UPLOAD_DIR=../../uploads
MAX_UPLOAD_SIZE_MB=50

# Upload storage backend
# local | s3 | minio
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mchat-uploads
S3_USE_SSL=false
# Optional public URL prefix, e.g. https://cdn.example.com/mchat
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
# Signed /uploads URLs (new uploads include ?exp=&sig=; legacy tokenless still work when false)
UPLOADS_REQUIRE_SIGNED_ACCESS=false
UPLOADS_SIGNED_URL_TTL_SECONDS=31536000

# Speech-to-text (chat / widget voice input)
STT_ENABLED=true
# openai = Whisper API (needs key); local = faster-whisper (pip install faster-whisper)
STT_PROVIDER=openai
STT_OPENAI_API_KEY=
# Or reuse: OPENAI_API_KEY=sk-...
STT_MODEL=whisper-1
STT_LANGUAGE=zh
STT_MAX_AUDIO_MB=10
STT_LOCAL_MODEL=base

# Database
# 本地开发 MySQL（先运行: docker compose -f ops/docker/docker-compose.dev.yml up -d）
DATABASE_URL=mysql+aiomysql://mchat:mchat_dev@localhost:3306/mchat_dev

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Milvus (optional - RAG feature)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ENABLED=false

# LLM API keys (optional fallback when an AI config row has an empty key)
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# MOONSHOT_API_KEY=sk-...

# Embedding (global defaults; each knowledge base can override)
# 推荐本地 Ollama：ollama pull nomic-embed-text
# Embedding：建议在管理后台「知识库 → 系统默认 Embedding」配置并保存（写入 DB），无需在此设置。
# 下列仅在未保存后台配置时作为兜底：
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_BASE=http://localhost:11434
# EMBEDDING_DIMENSION=768
# EMBEDDING_API_KEY=
# 本地上传 Embedding 模型 zip 大小上限（MB）
EMBEDDING_MODEL_MAX_MB=2048

# Redis (OTP for Cloud portal signup; rate limiting)
REDIS_URL=redis://localhost:6379/0

# Cloud portal: phone SMS signup (dev: fixed code; prod: Aliyun like 9235.net)
SMS_DEV_MODE=true
SMS_DEV_CODE=123456
OTP_EXPIRE_SECONDS=600
OTP_SEND_COOLDOWN_SECONDS=60
# Same Aliyun account/template as patentapi (basebase.xml + SMS_289525897)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=笑溢网络
ALIYUN_SMS_TEMPLATE_CODE=SMS_289525897
ALIYUN_SMS_REGION=cn-hangzhou

# 9235.net SSO (same JWT secret as patentapi JWTUtil; productId=pdmchat)
PATENT9235_JWT_SECRET=
PATENT9235_SSO_PRODUCT_ID=pdmchat
PATENT9235_SSO_CHANNEL_ID=mchat01
PATENT9235_SSO_LOGIN_URL=https://www.9235.net/user/login

# Payment (same as www.9235.net / buycdk — keys from patentapi config.properties)
MCHAT_PUBLIC_BASE_URL=https://mchat.9235.net
ALIPAY_APP_ID=2021004152628243
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
WECHAT_PAY_APP_ID=wx72863a0d11e809e0
WECHAT_PAY_MCH_ID=1679561189
WECHAT_PAY_API_KEY=

# Encrypt skill_bindings secrets at rest (Fernet; generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRETS_ENCRYPTION_KEY=
INVOICE_COMPANY_NAME=MChat Cloud
INVOICE_COMPANY_TAX_ID=
INVOICE_SUPPORT_EMAIL=support@9235.net

# Default admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# Skills directory
SKILLS_DIR=./skills

# File uploads
UPLOAD_DIR=../../uploads
MAX_UPLOAD_SIZE_MB=50

# Upload storage backend
# local | s3 | minio
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mchat-uploads
S3_USE_SSL=false
# Optional public URL prefix, e.g. https://cdn.example.com/mchat
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# Speech-to-text (chat / widget voice input)
STT_ENABLED=true
# openai = Whisper API (needs key); local = faster-whisper (pip install faster-whisper)
STT_PROVIDER=openai
STT_OPENAI_API_KEY=
# Or reuse: OPENAI_API_KEY=sk-...
STT_MODEL=whisper-1
STT_LANGUAGE=zh
STT_MAX_AUDIO_MB=10
STT_LOCAL_MODEL=base

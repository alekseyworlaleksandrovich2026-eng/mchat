# Database
# 本地开发 MySQL（先运行: docker compose -f ops/docker/docker-compose.dev.yml up -d）
DATABASE_URL=mysql+aiomysql://mchat:mchat_dev@localhost:3306/mchat_dev

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Milvus (optional - RAG feature)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ENABLED=false

# Embedding (global defaults; each knowledge base can override)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_BASE=
EMBEDDING_DIMENSION=1536
# 本地上传 Embedding 模型 zip 大小上限（MB）
EMBEDDING_MODEL_MAX_MB=2048

# Redis (optional - rate limiting, caching)
REDIS_URL=redis://localhost:6379/0

# Default admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# Skills directory
SKILLS_DIR=./skills

# File uploads
UPLOAD_DIR=../../uploads
MAX_UPLOAD_SIZE_MB=50

# Upload storage backend
# local | s3 | minio
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mchat-uploads
S3_USE_SSL=false
# Optional public URL prefix, e.g. https://cdn.example.com/mchat
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# Speech-to-text (chat / widget voice input)
STT_ENABLED=true
# openai = Whisper API (needs key); local = faster-whisper (pip install faster-whisper)
STT_PROVIDER=openai
STT_OPENAI_API_KEY=
# Or reuse: OPENAI_API_KEY=sk-...
STT_MODEL=whisper-1
STT_LANGUAGE=zh
STT_MAX_AUDIO_MB=10
STT_LOCAL_MODEL=base
